{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HotRedMat/ensembra/schemas/config.json",
  "title": "Ensembra User Config",
  "description": "사용자 설정 (~/.config/ensembra/config.json). /ensembra:config 선택형 picker 가 저장",
  "type": "object",
  "required": ["version", "performers"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "스키마 버전. 마이그레이션에 사용."
    },
    "plan_tier": {
      "type": "string",
      "enum": ["pro", "max"],
      "default": "pro",
      "description": "Claude 플랜 기반 실행 프로파일. pro = Claude Pro 사용자 기준 (Deep Scan 압축, Context Snapshot 요약, R2 diff 전달, Audit 1명). max = Claude Max 사용자 기준 (preset 원본 동작 유지). 우선순위: /ensembra:run --tier=... 인자 > 본 필드 > 'pro'. 세부 규칙은 CONTRACT.md §17 및 skills/run/SKILL.md 의 Tier Resolution 섹션 참조."
    },
    "external_first": {
      "type": "boolean",
      "default": false,
      "description": "v0.8.0+. true 면 Conductor 가 Claude 서브에이전트 폴백을 사용할 때 배지에 추가 경고를 표시하고, 외부 Transport(MCP/Ollama) 가용 시 무조건 외부 경로를 우선 시도한다. 금지선(planner/scribe Claude 고정, Phase 2 Execute Claude 본체 전담) 은 tier 와 동일하게 보호된다. 기본값 false 는 v0.7.x 동작을 보존한다."
    },
    "performers": {
      "type": "object",
      "description": "역할별 Transport·모델 매핑",
      "properties": {
        "planner":         { "$ref": "#/$defs/performerConfig" },
        "architect":       { "$ref": "#/$defs/performerConfig" },
        "developer":       { "$ref": "#/$defs/performerConfig" },
        "security":        { "$ref": "#/$defs/performerConfig" },
        "qa":              { "$ref": "#/$defs/performerConfig" },
        "devils-advocate": { "$ref": "#/$defs/performerConfig" },
        "scribe":          { "$ref": "#/$defs/performerConfig" }
      },
      "additionalProperties": false
    },
    "fallback": {
      "type": "object",
      "description": "외부 Transport 실패 시 최종 폴백",
      "properties": {
        "transport": { "type": "string", "const": "claude-subagent" },
        "model": { "type": "string" }
      }
    },
    "rounds": {
      "type": "object",
      "properties": {
        "r2_trigger_file_count": { "type": "integer", "minimum": 1, "default": 5 },
        "r2_trigger_consensus":  { "type": "integer", "minimum": 0, "maximum": 100, "default": 70 },
        "synthesis_consensus":   { "type": "integer", "minimum": 0, "maximum": 100, "default": 70 },
        "halt_consensus":        { "type": "integer", "minimum": 0, "maximum": 100, "default": 40 },
        "rework_limit":          { "type": "integer", "minimum": 0, "default": 2 }
      }
    },
    "deep_scan": {
      "type": "object",
      "description": "Deep Scan 체크리스트 10항목. 강제 6개는 항상 true.",
      "properties": {
        "item_1_structure":        { "type": "boolean", "const": true },
        "item_2_keyword_trace":    { "type": "boolean", "const": true },
        "item_3_call_graph":       { "type": "boolean", "const": true },
        "item_4_data_flow":        { "type": "boolean", "const": true },
        "item_5_test_map":         { "type": "boolean", "default": true },
        "item_6_git_history":      { "type": "boolean", "default": true },
        "item_7_dependencies":     { "type": "boolean", "default": true },
        "item_8_configuration":    { "type": "boolean", "default": true },
        "item_9_reuse_inventory":  { "type": "boolean", "const": true },
        "item_10_docs_inventory":  { "type": "boolean", "const": true }
      }
    },
    "transports": {
      "type": "object",
      "description": "Transport settings. Gemini API key is NOT stored here — it lives in the OS keychain via the plugin userConfig.gemini_api_key mechanism (plugin.json). This config.json holds only non-sensitive transport settings.",
      "properties": {
        "ollama": {
          "type": "object",
          "properties": {
            "endpoint": { "type": "string", "format": "uri", "default": "http://localhost:11434" }
          }
        },
        "gemini": {
          "type": "object",
          "properties": {
            "_comment": { "type": "string", "description": "Gemini API key is managed via plugin userConfig. Do not store the key in this file." }
          }
        }
      }
    },
    "timeouts": {
      "type": "object",
      "properties": {
        "ollama_sec":          { "type": "integer", "minimum": 1, "default": 120 },
        "gemini_sec":          { "type": "integer", "minimum": 1, "default": 60 },
        "claude_subagent_sec": { "type": "integer", "minimum": 1, "default": 300 },
        "deep_scan_sec":       { "type": "integer", "minimum": 1, "default": 180 }
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "level": { "type": "string", "enum": ["quiet", "normal", "verbose"], "default": "normal" },
        "extra_mask_keys": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "show_fallback_badge": { "type": "boolean", "default": true },
        "show_transport_badge": { "type": "boolean", "default": true, "description": "Phase 1 시작 시 각 Performer 의 Transport/Model 배지를 출력한다." }
      }
    },
    "reports": {
      "type": "object",
      "properties": {
        "task_report":  { "type": "boolean", "const": true },
        "design_doc":   { "type": "boolean", "default": true },
        "request_spec": { "type": "boolean", "default": true },
        "daily":        { "type": "boolean", "default": true },
        "weekly":       { "type": "boolean", "default": true },
        "path_tasks":     { "type": "string", "default": "docs/reports/tasks" },
        "path_daily":     { "type": "string", "default": "docs/reports/daily" },
        "path_weekly":    { "type": "string", "default": "docs/reports/weekly" },
        "path_design":    { "type": "string", "default": "docs/design" },
        "path_requests":  { "type": "string", "default": "docs/requests" },
        "path_transfer":  { "type": "string", "default": "docs/transfer" },
        "language": {
          "type": "string",
          "enum": ["auto", "ko", "en"],
          "default": "auto"
        },
        "transfer_scope_default": {
          "type": "string",
          "enum": ["project", "interactive"],
          "default": "project"
        },
        "transfer_template": {
          "type": "string",
          "enum": ["standard", "brief"],
          "default": "standard"
        },
        "transfer_include_devils_advocate_section": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "reuse_first": {
      "type": "object",
      "description": "Reuse-First 교차 원칙 장치 4개 토글. Cascade 규칙은 /ensembra:config 가 자동 처리.",
      "properties": {
        "device_1_inventory":        { "type": "boolean", "default": true },
        "device_2_schema_field":     { "type": "boolean", "default": true },
        "device_3_auto_disagree":    { "type": "boolean", "default": true },
        "device_4_synthesis_report": { "type": "boolean", "default": true },
        "quick_preset": {
          "type": "string",
          "enum": ["Maximum", "Strong", "Balanced", "Advisory", "Off", "Custom"],
          "default": "Maximum"
        }
      }
    }
  },
  "$defs": {
    "performerConfig": {
      "type": "object",
      "required": ["transport", "model"],
      "properties": {
        "transport": {
          "type": "string",
          "enum": ["claude-subagent", "gemini", "ollama", "mcp"],
          "description": "단일 Transport 선언 (v0.7.x 호환). transport_chain 이 제공되면 그 쪽이 우선한다."
        },
        "mcp_server_name": {
          "type": "string",
          "description": "MCP server 이름 (transport=mcp 일 때 필수). settings.local.json mcpServers 키와 일치해야 한다."
        },
        "mcp_tool_name": {
          "type": "string",
          "description": "v0.8.0+. MCP server 가 제공하는 tool 이름. 생략 시 역할 이름에서 유추 (예: architect → architect_deliberate)."
        },
        "model": { "type": "string" },
        "endpoint": { "type": "string", "format": "uri" },
        "timeout_sec": { "type": "integer", "minimum": 1 },
        "enabled": { "type": "boolean", "default": true },
        "transport_chain": {
          "type": "array",
          "description": "v0.8.0+. 다단 Transport 폴백 체인. 각 항목은 순서대로 시도되고 실패 시 다음으로 폴백한다. Transport 구현은 CONTRACT.md §8.8 참조. 체인이 선언되면 본 객체의 단일 transport/model 은 무시된다.",
          "minItems": 1,
          "items": { "$ref": "#/$defs/transportStep" }
        }
      }
    },
    "transportStep": {
      "type": "object",
      "required": ["transport"],
      "description": "v0.8.0+. transport_chain 의 한 단계. CONTRACT.md §8.8 Transport Fallback Chain Protocol 참조.",
      "properties": {
        "transport": {
          "type": "string",
          "enum": ["claude-subagent", "ollama", "mcp"],
          "description": "gemini 은 enum 에서 제외 (v0.6.0 구조적 폐지). MCP server 경유로만 Gemini 호출."
        },
        "mcp_server_name": { "type": "string" },
        "mcp_tool_name": { "type": "string" },
        "model": { "type": "string" },
        "endpoint": { "type": "string", "format": "uri" },
        "timeout_sec": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
