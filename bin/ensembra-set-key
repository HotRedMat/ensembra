#!/bin/sh
# ensembra-set-key — Interactive Gemini API key setup for Ensembra
#
# Reads a key from /dev/tty with echo disabled, writes it to
# ~/.config/ensembra/env with chmod 600, and verifies with a live
# Gemini API call. Does not touch shell history, clipboard, or any
# Claude Code conversation record.
#
# Usage:
#   ensembra-set-key               # interactive setup
#   ensembra-set-key --status      # show current key state (no secret output)
#   ensembra-set-key --clear       # delete the saved key
#   ensembra-set-key --verify      # test the saved key against Gemini API
#
# Store location: ~/.config/ensembra/env
# Format: GEMINI_API_KEY=AIza...
# Permissions: 0600 (user read/write only)
#
# Security notes:
# - Key is read from /dev/tty so it does not pass through stdin of any parent
#   process (Claude Code Bash tool has no stdin). Input is never echoed.
# - Key value never appears in script stdout. Only length, preview (first/last
#   4 chars), and verification result are printed.
# - Temporary variables are `unset` before exit.
# - Intended to be run directly in a terminal. If invoked from a non-TTY
#   context (e.g. Claude Code Bash tool), it exits with a clear instruction.

set -eu

ENSEMBRA_DIR="${HOME}/.config/ensembra"
ENV_FILE="${ENSEMBRA_DIR}/env"

usage() {
  cat <<USAGE
ensembra-set-key — Interactive Gemini API key setup

Usage:
  ensembra-set-key           Start interactive setup
  ensembra-set-key --status  Show current key state
  ensembra-set-key --clear   Delete the saved key
  ensembra-set-key --verify  Test the saved key against the Gemini API
  ensembra-set-key --help    This help

Key is saved to: ${ENV_FILE}
USAGE
}

mask_length() {
  printf 'length=%d' "${1:-0}"
}

mask_preview() {
  # Prints first 4 + last 4 chars, obscuring the middle
  _k="$1"
  _len=${#_k}
  if [ "$_len" -lt 12 ]; then
    printf '(too short to preview)'
  else
    printf '%s...%s' "$(printf '%s' "$_k" | cut -c1-4)" "$(printf '%s' "$_k" | tail -c 4)"
  fi
}

read_key_from_env_file() {
  if [ -f "$ENV_FILE" ]; then
    _line=$(grep '^GEMINI_API_KEY=' "$ENV_FILE" 2>/dev/null || true)
    if [ -n "$_line" ]; then
      printf '%s\n' "${_line#GEMINI_API_KEY=}"
      return 0
    fi
  fi
  return 1
}

status() {
  printf 'Ensembra Gemini API key status\n'
  printf '  file: %s\n' "$ENV_FILE"
  if [ -f "$ENV_FILE" ]; then
    _perms=$(stat -f '%Lp' "$ENV_FILE" 2>/dev/null || stat -c '%a' "$ENV_FILE" 2>/dev/null || echo '?')
    _mtime=$(stat -f '%Sm' "$ENV_FILE" 2>/dev/null || stat -c '%y' "$ENV_FILE" 2>/dev/null || echo '?')
    printf '  perms: %s\n' "$_perms"
    printf '  mtime: %s\n' "$_mtime"
    if _key=$(read_key_from_env_file); then
      printf '  key:   ✓ set (%s, preview=%s)\n' "$(mask_length "${#_key}")" "$(mask_preview "$_key")"
    else
      printf '  key:   ✗ file exists but no GEMINI_API_KEY line\n'
    fi
    unset _key
  else
    printf '  key:   ✗ not set (file does not exist)\n'
  fi
}

verify() {
  if ! _key=$(read_key_from_env_file); then
    printf '✗ no key to verify (run ensembra-set-key first)\n' >&2
    return 1
  fi
  if [ -z "$_key" ]; then
    printf '✗ empty key in %s\n' "$ENV_FILE" >&2
    unset _key
    return 1
  fi
  printf 'Verifying key against Gemini API (/v1beta/models)...\n'
  _response=$(curl -s -m 10 "https://generativelanguage.googleapis.com/v1beta/models?key=$_key" 2>/dev/null || echo '')
  unset _key
  if [ -z "$_response" ]; then
    printf '✗ curl failed (network error or timeout)\n' >&2
    return 1
  fi
  if printf '%s' "$_response" | grep -q '"models"'; then
    _count=$(printf '%s' "$_response" | grep -c '"name":')
    printf '✓ verified (models accessible: ~%s)\n' "$_count"
    return 0
  fi
  printf '✗ API error:\n' >&2
  printf '%s\n' "$_response" | sed -n 's/.*"message":[[:space:]]*"\([^"]*\)".*/  \1/p' | head -3 >&2
  return 1
}

clear_key() {
  if [ ! -f "$ENV_FILE" ]; then
    printf '(no key file to clear at %s)\n' "$ENV_FILE"
    return 0
  fi
  rm -f "$ENV_FILE"
  printf '✓ cleared %s\n' "$ENV_FILE"
  # Try to remove the parent dir if empty (non-fatal)
  rmdir "$ENSEMBRA_DIR" 2>/dev/null || true
}

setup_interactive() {
  # Require a TTY — we cannot read a secret from Claude Code's non-interactive Bash tool
  if [ ! -c /dev/tty ] || [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
    cat >&2 <<MSG
ensembra-set-key requires an interactive terminal (TTY).
You appear to be running inside a non-interactive context (for example,
Claude Code's Bash tool, a CI job, or a pipe).

To set up the Gemini API key, open a real terminal and run:

  ensembra-set-key

The script will prompt you for the key with input hidden, save it to
~/.config/ensembra/env with chmod 600, and verify it with a live API
call. Nothing is written to shell history, clipboard, or any Claude
Code conversation record.
MSG
    return 2
  fi

  printf '\n' > /dev/tty
  printf '╔══════════════════════════════════════════════════════╗\n' > /dev/tty
  printf '║  Ensembra — Gemini API key setup                     ║\n' > /dev/tty
  printf '╚══════════════════════════════════════════════════════╝\n' > /dev/tty
  printf '\n' > /dev/tty
  printf 'Get a free API key at https://aistudio.google.com/app/apikey\n' > /dev/tty
  printf '\n' > /dev/tty
  printf 'Paste the key below. Input will be hidden and never echoed,\n' > /dev/tty
  printf 'written to shell history, or sent to any Claude Code session.\n' > /dev/tty
  printf '\n' > /dev/tty
  printf 'Gemini API key (paste + Enter, or Ctrl+C to cancel): ' > /dev/tty

  # Read with echo off
  _saved_stty=$(stty -g < /dev/tty)
  stty -echo < /dev/tty
  trap 'stty "$_saved_stty" < /dev/tty 2>/dev/null || true; echo "" > /dev/tty' INT TERM EXIT
  IFS= read -r _key < /dev/tty || {
    stty "$_saved_stty" < /dev/tty 2>/dev/null || true
    printf '\n(cancelled)\n' > /dev/tty
    unset _key
    return 1
  }
  stty "$_saved_stty" < /dev/tty 2>/dev/null || true
  printf '\n' > /dev/tty
  trap - INT TERM EXIT

  if [ -z "$_key" ]; then
    printf '✗ empty key, aborting\n' >&2
    unset _key
    return 1
  fi

  case "$_key" in
    AIza*) : ;;  # likely Google API key
    *)
      printf '⚠ key does not start with "AIza" — are you sure this is a Gemini key? (y/n) ' > /dev/tty
      read -r _confirm < /dev/tty
      case "$_confirm" in
        y|Y|yes|YES) : ;;
        *)
          printf '(cancelled)\n' > /dev/tty
          unset _key _confirm
          return 1
          ;;
      esac
      unset _confirm
      ;;
  esac

  umask 077
  mkdir -p "$ENSEMBRA_DIR"
  chmod 700 "$ENSEMBRA_DIR"

  # Write atomically: to a temp file first, then rename
  _tmp="${ENV_FILE}.tmp.$$"
  printf 'GEMINI_API_KEY=%s\n' "$_key" > "$_tmp"
  chmod 600 "$_tmp"
  mv "$_tmp" "$ENV_FILE"
  unset _tmp

  _len=${#_key}
  _preview=$(mask_preview "$_key")
  unset _key

  printf '✓ key saved to %s\n' "$ENV_FILE" > /dev/tty
  printf '  length: %d\n' "$_len" > /dev/tty
  printf '  preview: %s\n' "$_preview" > /dev/tty
  printf '  perms: 600\n' > /dev/tty

  unset _len _preview

  printf '\nVerifying...\n' > /dev/tty
  if verify > /dev/tty 2>&1; then
    printf '\n✓ setup complete. Ensembra architect performer will now use Gemini.\n' > /dev/tty
  else
    printf '\n⚠ saved the key, but API verification failed.\n' > /dev/tty
    printf '  Check the key at https://aistudio.google.com/app/apikey\n' > /dev/tty
    printf '  Run "ensembra-set-key --verify" after confirming.\n' > /dev/tty
  fi
}

case "${1:-}" in
  -h|--help)     usage ;;
  --status)      status ;;
  --clear)       clear_key ;;
  --verify)      verify ;;
  '')            setup_interactive ;;
  *)             usage; exit 1 ;;
esac
